{
  "name": "lancedb-connector",
  "version": "1.0.0",
  "description": "HTTP API and MCP bridge for LanceDB OSS (TypeScript / Fastify)",
  "main": "dist/main.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:mcp": "node dist/mcp-server.js",
    "dev": "tsx watch src/main.ts",
    "dev:mcp": "tsx watch src/mcp-server.ts"
  },
  "keywords": [
    "lancedb",
    "vector",
    "mcp",
    "fastify"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
